{
  "name": "workforests",
  "version": "0.1.0",
  "description": "Interactive shell tool for managing git worktrees, bundled as forests across multiple repositories.",
  "type": "module",
  "license": "MIT",
  "author": "Christopher Bischoff",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marsvogel/WorkForests.git"
  },
  "homepage": "https://github.com/marsvogel/WorkForests#readme",
  "bugs": {
    "url": "https://github.com/marsvogel/WorkForests/issues"
  },
  "keywords": [
    "git",
    "worktree",
    "cli",
    "ink",
    "terminal",
    "tui",
    "monorepo",
    "multi-repo"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "workforests": "./dist/cli.js"
  },
  "scripts": {
    "build": "esbuild src/cli.tsx --bundle --platform=node --format=esm --target=node20 --packages=external --outfile=dist/cli.js --banner:js=\"#!/usr/bin/env node\" --legal-comments=none && chmod +x dist/cli.js",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "fuzzysort": "^3.1.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "esbuild": "^0.24.2",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
